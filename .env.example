# ─── Profile & Environment ──────────────────────────────────────────────────
PROFILE=api
# Options: qa | prod | on_premise | it
ENVIRONMENT=qa

# ─── API HTTP Client ─────────────────────────────────────────────────────────
API_HTTP_CLIENT.URL=https://api.example.com
API_HTTP_CLIENT.TIMEOUT=30

# ─── Default credentials (used for global-setup token) ───────────────────────
AUTH_CREDENTIALS.EMAIL=user@example.com
AUTH_CREDENTIALS.PASSWORD=supersecret
AUTH_CREDENTIALS.OTP_SECRET=YOUR_TOTP_BASE32_SECRET

# ─── Role credentials ────────────────────────────────────────────────────────
AUTH_CREDENTIALS_SUPER_ADMIN.EMAIL=super_admin@example.com
AUTH_CREDENTIALS_SUPER_ADMIN.PASSWORD=supersecret
AUTH_CREDENTIALS_ADMIN.EMAIL=admin@example.com
AUTH_CREDENTIALS_ADMIN.PASSWORD=supersecret
AUTH_CREDENTIALS_USER.EMAIL=user@example.com
AUTH_CREDENTIALS_USER.PASSWORD=supersecret

# ─── Org / User identifiers ──────────────────────────────────────────────────
ORG_NAME=acme-corp
ORG_ROLE_ID=507f1f77bcf86cd799439022
USER_NAME=johndoe
USER_ID=607f1f77bcf86cd799439011
USER_ROLE_ID=507f1f77bcf86cd799439021
USER_BASE_URL=https://app.example.com

# ─── QA Environment ──────────────────────────────────────────────────────────
QA_API_URL=https://api.qa.example.com
QA_UI_URL=https://qa.example.com
QA_ORG_NAME=automation
QA_ORG_ID=6819f4ac17826e64445c9003
QA_ADMIN_ID=
QA_ADMIN_EMAIL=
QA_REGULAR_ID=
QA_REGULAR_EMAIL=

# ─── Production Environment ───────────────────────────────────────────────────
PROD_API_URL=https://api.prod.example.com
PROD_UI_URL=https://app.example.com
PROD_ORG_NAME=kaleidoo
PROD_ORG_ID=
PROD_ADMIN_ID=
PROD_ADMIN_EMAIL=
PROD_REGULAR_ID=
PROD_REGULAR_EMAIL=

# ─── On-Premise Environment ───────────────────────────────────────────────────
ONPREM_API_URL=https://api.onprem.example.com
ONPREM_UI_URL=https://onprem.example.com
ONPREM_ORG_NAME=automation
ONPREM_ORG_ID=6819f4ac17826e64445c9003
ONPREM_ADMIN_ID=
ONPREM_ADMIN_EMAIL=
ONPREM_REGULAR_ID=
ONPREM_REGULAR_EMAIL=

# ─── IT Environment ───────────────────────────────────────────────────────────
IT_API_URL=https://api.it.example.com
IT_UI_URL=https://it.example.com
IT_ORG_NAME=automation
IT_ORG_ID=
IT_ADMIN_ID=
IT_ADMIN_EMAIL=

# ─── E2E (UI) Settings ───────────────────────────────────────────────────────
E2E_BASE_URL=https://app.example.com
E2E_BROWSER_NAME=chromium
E2E_HEADLESS=true
E2E_SLOW_MO_MS=0
E2E_DEFAULT_TIMEOUT_MS=30000
