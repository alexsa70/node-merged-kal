{
  "name": "node-playwright",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright + TypeScript API/E2E test project migrated from Python pytest + Playwright",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:e2e": "playwright test --project=e2e",
    "test:login": "playwright test tests/api/login --project=api",
    "test:rbac": "playwright test tests/api/rbac --project=api",
    "report": "playwright show-report",
    "allure:generate": "allure generate ./allure-results -o ./allure-report --clean",
    "allure:open": "allure open ./allure-report",
    "allure:serve": "allure serve ./allure-results"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.8.0",
    "@playwright/test": "^1.56.0",
    "allure-commandline": "^2.34.1",
    "allure-playwright": "^3.4.1",
    "dotenv": "^16.6.1",
    "otplib": "^12.0.1",
    "typescript": "^5.9.3"
  }
}
