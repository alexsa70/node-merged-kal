{
  "name": "node-playwright",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright + TypeScript API/E2E test project migrated from Python pytest + Playwright",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:e2e": "playwright test --project=e2e",
    "test:e2e:qa": "dotenv -e .env.qa -- playwright test --project=e2e",
    "test:e2e:onprem": "dotenv -e .env.on_premise -- playwright test --project=e2e",
    "test:e2e:prod": "dotenv -e .env.prod -- playwright test --project=e2e",
    "test:smoke": "playwright test --project=api --grep=smoke",
    "test:login": "playwright test tests/api/login --project=api",
    "test:rbac": "playwright test tests/api/rbac --project=api",
    "test:tags": "playwright test tests/api/tags --project=api",
    "test:files": "playwright test tests/api/files --project=api",
    "test:projects": "playwright test tests/api/projects --project=api",
    "test:general": "playwright test tests/api/general --project=api",
    "test:visual": "playwright test --project=visual --workers=2",
    "test:visual:qa": "dotenv -e .env.qa -- playwright test --project=visual --workers=2",
    "test:visual:onprem": "dotenv -e .env.on_premise -- playwright test --project=visual --workers=2",
    "test:visual:prod": "dotenv -e .env.prod -- playwright test --project=visual --workers=2",
    "test:visual:update": "playwright test --project=visual --update-snapshots --workers=2",
    "test:visual:update:qa": "dotenv -e .env.qa -- playwright test --project=visual --update-snapshots --workers=2",
    "test:visual:update:onprem": "dotenv -e .env.on_premise -- playwright test --project=visual --update-snapshots --workers=2",
    "test:visual:update:prod": "dotenv -e .env.prod -- playwright test --project=visual --update-snapshots --workers=2",
    "ci:api": "bash scripts/run-tests.sh --project=api",
    "ci:e2e": "bash scripts/run-tests.sh --project=e2e",
    "ci:visual": "bash scripts/run-tests.sh --project=visual",
    "ci:visual:update": "bash scripts/run-tests.sh --project=visual --update-snapshots",
    "report": "playwright show-report",
    "allure:generate": "allure generate ./allure-results -o ./allure-report --clean",
    "allure:open": "allure open ./allure-report",
    "allure:serve": "allure serve ./allure-results",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.8.0",
    "@playwright/test": "^1.56.0",
    "@types/node": "^25.5.0",
    "allure-commandline": "^2.34.1",
    "allure-playwright": "^3.4.1",
    "dotenv": "^16.6.1",
    "dotenv-cli": "^11.0.0",
    "otplib": "^12.0.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
